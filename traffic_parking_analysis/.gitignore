# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/
dist/
build/
*.so
*.dll

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
aiml/
conda-env/

# ── Environment variables / secrets ──────────────────────────────────────────
.env
.env.local
*.env
secrets.py

# ── YOLOv8 model weights (large files — download on first run) ────────────────
models/*.pt
*.pt
*.onnx
*.engine
*.tflite

# ── Uploaded & processed videos (can be large) ───────────────────────────────
dataset/traffic_videos/*
!dataset/traffic_videos/.gitkeep

outputs/processed_videos/*
!outputs/processed_videos/.gitkeep

# ── Job store (machine-specific runtime state) ────────────────────────────────
outputs/jobs.json

# ── Other output folders ──────────────────────────────────────────────────────
outputs/graphs/*
!outputs/graphs/.gitkeep

outputs/reports/*
!outputs/reports/.gitkeep

# ── React / Node ──────────────────────────────────────────────────────────────
frontend-react/node_modules/
frontend-react/build/
frontend-react/.env.local
frontend-react/.env.production

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/